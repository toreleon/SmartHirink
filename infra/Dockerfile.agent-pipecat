FROM python:3.12-slim AS base
WORKDIR /app

RUN apt-get update && \
    apt-get install -y --no-install-recommends gcc libffi-dev libssl-dev \
    libgl1 libglib2.0-0 libxcb1 libxext6 libsm6 libxrender1 && \
    rm -rf /var/lib/apt/lists/*

COPY apps/agent-pipecat/pyproject.toml ./
RUN pip install --no-cache-dir .

COPY apps/agent-pipecat/ ./
COPY apps/api/prisma/schema.prisma ./prisma/schema.prisma
RUN python -m prisma generate --schema=prisma/schema.prisma --generator py

EXPOSE 7860
CMD ["uvicorn", "server:app", "--host", "0.0.0.0", "--port", "7860"]
