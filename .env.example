# ========================
# SmartHirink Environment
# ========================

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smarthirink?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Pipecat Agent
AGENT_URL=http://localhost:7860

# Deepgram (STT + TTS)
DEEPGRAM_API_KEY=

# OpenAI (LLM)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=

# Deepgram TTS voice
DEEPGRAM_TTS_MODEL=aura-2-thalia-en

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=SmartHirink <noreply@smarthirink.com>

# Observability
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# App
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
