# ========================
# SmartHirink Environment
# ========================

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smarthirink?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# LiveKit
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
LIVEKIT_URL=ws://localhost:7880

# STT Provider (deepgram | google | azure)
STT_PROVIDER=deepgram
DEEPGRAM_API_KEY=
GOOGLE_STT_CREDENTIALS=
AZURE_STT_KEY=
AZURE_STT_REGION=

# LLM Provider (openai | azure_openai | anthropic)
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=
ANTHROPIC_API_KEY=

# TTS Provider (openai | azure | elevenlabs)
TTS_PROVIDER=openai
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
AZURE_TTS_KEY=
AZURE_TTS_REGION=

# Embedding (openai | azure)
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# Observability
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# App
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
